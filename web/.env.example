GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-2506
# MISTRAL_MODEL_FALLBACK=open-mistral-nemo
# LLM_PROVIDER=mistral
# LLM_PROXY=http://127.0.0.1:7890
# LLM_USE_SYSTEM_PROXY=1
# NO_PROXY=localhost,127.0.0.1
# Если Gemini недоступен (fetch failed) — укажи LLM_PROVIDER=groq или LLM_PROVIDER=mistral
# LLM_TIMEOUT_MS=120000
# LLM_MAX_RETRIES=1
# ANALYZE_RAG_MAX_CHUNKS=12
# GROQ_CHAT_MAX_TOKENS=1024
# GROQ_ANALYZE_MAX_TOKENS=1536
# MISTRAL_CHAT_MAX_TOKENS=1024
# MISTRAL_ANALYZE_MAX_TOKENS=4096
RAG_API_URL=http://127.0.0.1:8000
# TTS_API_URL=http://127.0.0.1:8000
# TTS_TIMEOUT_MS=60000
# TTS_WARMUP=1
DATABASE_URL=postgresql://postgres:secret@127.0.0.1:5433/pdd_rag
JWT_SECRET=change-me-in-production

# Логины с доступом к in-game редакторам (через запятую, без учёта регистра).
# Дополняет флаг is_admin в таблице users.
# ADMIN_LOGINS=admin,dev

# Vector RAG в чате (медленнее, но точнее). Модели грузятся при старте Docker.
# USE_RAG=1
# CHAT_RAG_TIMEOUT_MS=8000

# Reranker для rag-api (Docker читает из web/.env):
# SKIP_RERANKER=0
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_THRESHOLD=0

# Cloudpub / внешний туннель к `npm run dev` (порт 5173)
# Домен *.cloudpub.ru уже разрешён в vite.config.ts; для HMR укажите свой поддомен:
# VITE_TUNNEL_HOST=amiably-comforting-lab.cloudpub.ru
# VITE_TUNNEL_PORT=443
