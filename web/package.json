{
  "name": "pdd-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "dev": "concurrently -n vite,server -c cyan,yellow \"vite\" \"tsx watch --env-file=.env server/index.ts\"",
    "restart": "npm run stop && npm run dev",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "build": "tsc -b && vite build",
    "start": "tsx --env-file=.env server/index.ts",
    "preview": "vite preview",
    "build:data": "tsx scripts/build-data.ts",
    "audit:pdd": "python scripts/audit-pdd-content.py --report",
    "update:pdd": "python scripts/audit-pdd-content.py --apply --sync-scripts",
    "build:map": "node scripts/extract-city-map.mjs",
    "sync:map": "node scripts/sync-city-tiles.mjs",
    "build:mission1-map": "python scripts/build-tilemap-from-video.py",
    "stitch:mission1": "python scripts/stitch-mission1-anchored.py",
    "stitch:mission1:legacy": "python scripts/stitch-mission1-from-screens.py",
    "tilemap:mission1": "python scripts/build-mission1-tilemap.py",
    "sprites:transparent-mission2": "node scripts/remove-mission2-sprite-background.mjs",
    "sprites:transparent-mission2:all": "node scripts/remove-mission2-sprite-background.mjs --all",
    "sprites:transparent-mission2:rembg": "node scripts/remove-mission2-sprite-background.mjs --all --rembg",
    "optimize:mission2-overrides": "python scripts/optimize-composite-overrides.py",
    "merge:mission2-overrides-surfaces": "python scripts/merge-composite-overrides-surfaces.py",
    "test:review-plan": "tsx scripts/review-plan-titles.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.38.0",
    "pg": "^8.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "undici": "^8.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
